# ── Application ──────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
BASE_URL=https://api.spacecoaststudios.com

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=sqlite:///./homeservices.db
# Production (copy connection string from DigitalOcean managed database dashboard):
# DATABASE_URL=postgres://user:password@host:port/database?sslmode=require

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / Anthropic ────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-5

# ── Email / SendGrid ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@spacecoaststudios.com
FROM_NAME=Space Coast Studios

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production:
# ALLOWED_ORIGINS=https://dashboard.spacecoaststudios.com,https://spacecoaststudios.com

# ── Twilio (optional — for SMS) ───────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# ── Contact Form ──────────────────────────────────────────────────────────────
CONTACT_AUTO_RESPOND=true
CONTACT_MAX_SUGGESTED_SLOTS=5

# ── Scheduling Defaults ───────────────────────────────────────────────────────
DEFAULT_SLOT_GRANULARITY_MINUTES=30
DEFAULT_BUFFER_MINUTES=15
DEFAULT_MAX_ADVANCE_BOOKING_DAYS=30
DEFAULT_MIN_LEAD_TIME_HOURS=2
